@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="alert alert-danger mt-4">
    <h1 class="h5 alert-heading">An error occurred</h1>
    <p class="mb-0">Sorry, something went wrong while processing your request.</p>
</div>

@if (Model.ShowRequestId)
{
    <p class="text-muted small">Request ID: <code>@Model.RequestId</code></p>
}

<a class="btn btn-outline-secondary" asp-page="/Index">Back</a>
